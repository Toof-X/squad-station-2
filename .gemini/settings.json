{
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "squad-station signal $(tmux display-message -p '#S')"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "squad-station context --inject"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "squad-station notify --body 'Agent needs input' --agent $(tmux display-message -p '#S')"
          }
        ]
      }
    ]
  }
}